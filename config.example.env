# 產品與報價工具 後端設定範本
# 複製成 .env 或在主機的環境變數設定。未填的項目，對應的回存功能會顯示「尚未設定」。

# ── Google（服務帳號，寫 Drive/Sheets/Docs）──
# 服務帳號 JSON 金鑰檔路徑
GOOGLE_SA_JSON=/path/to/service-account.json
# 報價試算表要放的 Drive 資料夾 ID
GDRIVE_QUOTE_FOLDER=
# 提案要放的 Drive 資料夾 ID（07-02 提案簡報）
GDRIVE_PROPOSAL_FOLDER=
# 行程成本範本 JSON 要放的資料夾 ID（不填會沿用 GDRIVE_QUOTE_FOLDER）
GDRIVE_TEMPLATE_FOLDER=
# （進階）直接指定已存在的範本檔 file id，省去用檔名搜尋
GDRIVE_TEMPLATE_FILE_ID=
# 2B提案簡報檢索表 的試算表 ID（要附加新列）
INDEX_SHEET_ID=1CW2IX103O-LOPtOXvrwDoW7ybLL1gFKYE_71TheSAg8

# ── Zoho CRM（寫 Deal）──
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_DOMAIN=https://www.zohoapis.com

# ── 整站存取密碼（選填，避免外人開到；與下方個人登入是不同層）──
AUTH_USER=
AUTH_PASS=

# ── 個人登入（修改範本需登入；看／用範本免登入）──
# token 簽章密鑰：設一個固定的長亂碼，登入狀態才能跨「重新部署」保留（不設＝每次重部署需重登）
SESSION_SECRET=
# 登入有效天數（預設 30）
SESSION_TTL_DAYS=30

# ── 用 Google 登入，限定公司網域（推薦）──
# Google Cloud Console 建一個「OAuth 用戶端 ID（網頁應用程式）」，把它的 Client ID 填這裡。
# 授權的 JavaScript 來源要加上你的網址（例：https://你的app.up.railway.app，本機測試加 http://localhost:4181）
GOOGLE_OAUTH_CLIENT_ID=
# 只允許這個信箱網域登入（預設 walkin.tw）
ALLOWED_EMAIL_DOMAIN=walkin.tw
# 哪些信箱是管理員（逗號分隔；其餘登入者為一般業務）
ADMIN_EMAILS=chiuyi@walkin.tw

# ── 密碼登入（預設關閉；只給本機開發或 Google 故障時的救生艇用）──
# 設為 1 才會啟用下面的密碼登入；正式環境請維持空白＝關閉，達成「只能用公司信箱登入」
ALLOW_PASSWORD_LOGIN=
ADMIN_USER=admin
ADMIN_PASS=
ADMIN_NAME=管理員
# （進階）帳號清單 JSON 的 Drive file id；不填會放在 GDRIVE_TEMPLATE_FOLDER 並用檔名找
GDRIVE_USERS_FILE_ID=
