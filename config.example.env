# 產品與報價工具 後端設定範本
# 複製成 .env 或在主機的環境變數設定。未填的項目，對應的回存功能會顯示「尚未設定」。

# ── Google（服務帳號，寫 Drive/Sheets/Docs）──
# 服務帳號 JSON 金鑰檔路徑
GOOGLE_SA_JSON=/path/to/service-account.json
# 報價試算表要放的 Drive 資料夾 ID
GDRIVE_QUOTE_FOLDER=
# 提案要放的 Drive 資料夾 ID（07-02 提案簡報）
GDRIVE_PROPOSAL_FOLDER=
# 2B提案簡報檢索表 的試算表 ID（要附加新列）
INDEX_SHEET_ID=1CW2IX103O-LOPtOXvrwDoW7ybLL1gFKYE_71TheSAg8

# ── Zoho CRM（寫 Deal）──
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_DOMAIN=https://www.zohoapis.com

# ── 整站存取密碼（選填，避免外人開到）──
AUTH_USER=
AUTH_PASS=
